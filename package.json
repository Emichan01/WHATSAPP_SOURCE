{
  "name": "emlak-whatsapp",
  "version": "1.0.8",
  "description": "Ekşioğlu Connect — WhatsApp Pazarlama Otomasyonu",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3 || true",
    "build:mac": "electron-builder --mac --x64 --arm64",
    "build:win": "electron-builder --win --x64",
    "build:all": "electron-builder --mac --win --x64 --arm64"
  },
  "keywords": [
    "whatsapp",
    "emlak",
    "automation",
    "electron"
  ],
  "author": "Ekşioğlu Connect",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "electron-updater": "^6.8.3",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.26.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "appId": "com.emlak.whatsapp",
    "productName": "Ekşioğlu Connect",
    "copyright": "Ekşioğlu Connect 2025",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/bindings/**",
      "node_modules/file-uri-to-path/**",
      "node_modules/whatsapp-web.js/**",
      "node_modules/puppeteer/**",
      "node_modules/puppeteer-core/**",
      "node_modules/.cache/puppeteer/**"
    ],
    "files": [
      "src/**/*",
      "package.json",
      "!**/{.DS_Store,Thumbs.db,*.map}",
      "!**/node_modules/.cache/**"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "public.app-category.business",
      "artifactName": "EmlakWhatsApp-${version}-Mac-${arch}.${ext}",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Ekşioğlu Connect ${version}",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "EmlakWhatsApp-${version}-Windows-${arch}.${ext}",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ekşioğlu Connect",
      "artifactName": "EmlakWhatsApp-${version}-Kurulum.${ext}"
    },
    "portable": {
      "artifactName": "EmlakWhatsApp-${version}-Portable.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "emichan01",
      "repo": "WHATSAPP_SOURCE"
    }
  }
}
